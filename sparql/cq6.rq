# CQ6: Filtro por Area e Nivel Taxonomico
# (Learners at "Apply" proficiency level in the Programming area)
PREFIX : <http://www.ontolearn.com/ontologia#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?aprendizLabel WHERE {
  ?des :proficienciaAtingida :Aplicar ;
       :competenciaAvaliada ?comp .
  ?comp :area "Programacao" .
  ?aprendiz :desempenhoCompetencias ?des ;
            rdfs:label ?aprendizLabel .
}
