# CQ2: Nivel de proficiencia em competencia especifica
# (Proficiency level achieved by a learner in a specific competency)
PREFIX : <http://www.ontolearn.com/ontologia#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?nivelLabel WHERE {
  ?aprendiz rdfs:label "Joao Silva" .
  ?aprendiz :desempenhoCompetencias ?des .
  ?des :competenciaAvaliada ?comp ;
       :proficienciaAtingida ?nivel .
  ?comp rdfs:label "Heranca em Python" .
  ?nivel rdfs:label ?nivelLabel .
}
