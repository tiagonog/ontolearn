# CQ7: URLs no historico de aprendizagem
# (URLs of resources accessed in a learner's history)
PREFIX : <http://www.ontolearn.com/ontologia#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?url WHERE {
  ?aprendiz rdfs:label "Joao Silva" ;
            :historicoAprendizagem ?hist .
  ?hist :acessouRecurso ?rec .
  ?rec :url ?url .
}
