<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.ontolearn.com/ontologia#"
     xml:base="http://www.ontolearn.com/ontologia"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    
    <owl:Ontology rdf:about="http://www.ontolearn.com/ontologia">
        <rdfs:comment xml:lang="pt">Ontologia OntoLearn - Versão Final. Correção integral de P04, P08, P11 e P13.</rdfs:comment>
        <rdfs:label xml:lang="pt">OntoLearn</rdfs:label>
    </owl:Ontology>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#abordaCompetencia">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehAbordadaPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:label xml:lang="pt">aborda competência</rdfs:label>
        <rdfs:comment xml:lang="pt">Relaciona um recurso educacional à competência que ele visa desenvolver.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehAbordadaPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:label xml:lang="pt">é abordada por</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica quais recursos educacionais cobrem esta competência.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#aprendizAvaliado">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#teveDesempenhoAvaliado"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:label xml:lang="pt">aprendiz avaliado</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica o aprendiz a quem se refere este registro de desempenho.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#teveDesempenhoAvaliado">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:label xml:lang="pt">teve desempenho avaliado</rdfs:label>
        <rdfs:comment xml:lang="pt">Relaciona o aprendiz aos seus registros de avaliação de desempenho.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#aprendizesInscritos">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#estaInscritoEm"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:label xml:lang="pt">aprendizes inscritos</rdfs:label>
        <rdfs:comment xml:lang="pt">Lista os alunos matriculados no curso.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#estaInscritoEm">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:label xml:lang="pt">está inscrito em</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica os cursos em que o aprendiz está matriculado.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#avaliaDesempenho">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#temDesempenhoAvaliadoPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:label xml:lang="pt">avalia desempenho</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica que o instrutor realizou a avaliação de desempenho.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#temDesempenhoAvaliadoPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:label xml:lang="pt">tem desempenho avaliado por</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica o instrutor responsável por esta avaliação de desempenho.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#avaliacoesAplicadas">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#aplicadaNoCurso"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:label xml:lang="pt">avaliações aplicadas</rdfs:label>
        <rdfs:comment xml:lang="pt">Relaciona as avaliações que compõem o curso.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#aplicadaNoCurso">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:label xml:lang="pt">aplicada no curso</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica a qual curso a avaliação pertence.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#competenciaRelacionada">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#temQuestaoRelacionada"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:label xml:lang="pt">competência relacionada</rdfs:label>
        <rdfs:comment xml:lang="pt">Associa uma questão à competência que ela aborda.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#temQuestaoRelacionada">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:label xml:lang="pt">tem questão relacionada</rdfs:label>
        <rdfs:comment xml:lang="pt">Lista as questões relacionadas a esta competência.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#competenciasAvaliadas">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#avaliadaPelaQuestao"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:label xml:lang="pt">competências avaliadas</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica as competências que são medidas por esta questão.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#avaliadaPelaQuestao">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:label xml:lang="pt">avaliada pela questão</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica as questões usadas para avaliar esta competência.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#competenciasEnvolvidas">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehEnvolvidaEm"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ontolearn.com/ontologia#MilestoneDeAprendizagem"/>
                    <rdf:Description rdf:about="http://www.ontolearn.com/ontologia#TrajetoriasDeAprendizagem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:label xml:lang="pt">competências envolvidas</rdfs:label>
        <rdfs:comment xml:lang="pt">Competências trabalhadas em milestones ou trajetórias.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehEnvolvidaEm">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ontolearn.com/ontologia#MilestoneDeAprendizagem"/>
                    <rdf:Description rdf:about="http://www.ontolearn.com/ontologia#TrajetoriasDeAprendizagem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="pt">é envolvida em</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica milestones ou trajetórias que envolvem esta competência.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#conquistasAdquiridas">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#adquiridaPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#MilestoneDeAprendizagem"/>
        <rdfs:label xml:lang="pt">conquistas adquiridas</rdfs:label>
        <rdfs:comment xml:lang="pt">Marcos de aprendizagem alcançados pelo estudante.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#adquiridaPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#MilestoneDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:label xml:lang="pt">adquirida por</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica o aprendiz que adquiriu esta conquista.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#desempenhoCompetencias">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#competenciasDoDesempenho"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:label xml:lang="pt">desempenho em competências</rdfs:label>
        <rdfs:comment xml:lang="pt">Relaciona o aprendiz aos registros de seu desempenho.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#competenciasDoDesempenho">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:label xml:lang="pt">competências do desempenho</rdfs:label>
        <rdfs:comment xml:lang="pt">Relaciona o registro de desempenho ao aprendiz correspondente.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#elaboraAvaliacoes">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#elaboradaPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:label xml:lang="pt">elabora avaliações</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica que o instrutor criou a avaliação.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#elaboradaPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:label xml:lang="pt">elaborada por</rdfs:label>
        <rdfs:comment xml:lang="pt">Instrutor responsável pela criação da avaliação.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#exigeNivel">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehExigidoPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#NiveisDeProficiencia"/>
        <rdfs:label xml:lang="pt">exige nível</rdfs:label>
        <rdfs:comment xml:lang="pt">Nível de proficiência necessário para resolver a questão.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehExigidoPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#NiveisDeProficiencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:label xml:lang="pt">é exigido por</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica questões que exigem este nível de proficiência.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#fazParteDaAvaliacao">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#questoesIncluidas"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:label xml:lang="pt">faz parte da avaliação</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica a qual avaliação a questão pertence.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#questoesIncluidas">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:label xml:lang="pt">questões incluídas</rdfs:label>
        <rdfs:comment xml:lang="pt">Lista as questões que compõem a avaliação.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#historicoAprendizagem">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#parteDoHistoricoDe"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:label xml:lang="pt">histórico de aprendizagem</rdfs:label>
        <rdfs:comment xml:lang="pt">Registro dos recursos consumidos pelo aprendiz.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#parteDoHistoricoDe">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:label xml:lang="pt">parte do histórico de</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica o aprendiz cujo histórico contém este recurso.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#insereRecursos">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#inseridoPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:label xml:lang="pt">insere recursos</rdfs:label>
        <rdfs:comment xml:lang="pt">Indica que o instrutor disponibilizou um recurso.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#inseridoPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:label xml:lang="pt">inserido por</rdfs:label>
        <rdfs:comment xml:lang="pt">Instrutor que inseriu o recurso.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#instrutoresResponsaveis">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehResponsavelPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:label xml:lang="pt">instrutores responsáveis</rdfs:label>
        <rdfs:comment xml:lang="pt">Instrutores que ministram o curso.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehResponsavelPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:label xml:lang="pt">é responsável por</rdfs:label>
        <rdfs:comment xml:lang="pt">Cursos pelos quais o instrutor é responsável.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#proficienciaAtingida">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#foiAtingidaEm"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#NiveisDeProficiencia"/>
        <rdfs:label xml:lang="pt">proficiência atingida</rdfs:label>
        <rdfs:comment xml:lang="pt">Nível de proficiência demonstrado no desempenho.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#foiAtingidaEm">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#NiveisDeProficiencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:label xml:lang="pt">foi atingida em</rdfs:label>
        <rdfs:comment xml:lang="pt">Registros de desempenho onde este nível foi atingido.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#questaoRespondida">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#teveRespostaEm"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:label xml:lang="pt">questão respondida</rdfs:label>
        <rdfs:comment xml:lang="pt">Questão à qual o desempenho se refere.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#teveRespostaEm">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:label xml:lang="pt">teve resposta em</rdfs:label>
        <rdfs:comment xml:lang="pt">Desempenhos que respondem a esta questão.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#recursosUtilizados">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#utilizadoEm"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:label xml:lang="pt">recursos utilizados</rdfs:label>
        <rdfs:comment xml:lang="pt">Recursos didáticos usados no curso.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#utilizadoEm">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:label xml:lang="pt">utilizado em</rdfs:label>
        <rdfs:comment xml:lang="pt">Cursos onde este recurso é utilizado.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#requer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehRequeridaPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:label xml:lang="pt">requer</rdfs:label>
        <rdfs:comment xml:lang="pt">Prerrequisitos entre competências.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehRequeridaPor">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:label xml:lang="pt">é requerida por</rdfs:label>
        <rdfs:comment xml:lang="pt">Competências que exigem esta como pré-requisito.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#trajetoriasRealizadas">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#realizadaPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#TrajetoriasDeAprendizagem"/>
        <rdfs:label xml:lang="pt">trajetórias realizadas</rdfs:label>
        <rdfs:comment xml:lang="pt">Caminhos de aprendizagem seguidos pelo aluno.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#realizadaPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#TrajetoriasDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:label xml:lang="pt">realizada por</rdfs:label>
        <rdfs:comment xml:lang="pt">Aprendiz que realizou a trajetória.</rdfs:comment>
    </owl:ObjectProperty>

