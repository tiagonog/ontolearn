<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.ontolearn.com/ontologia#"
     xml:base="http://www.ontolearn.com/ontologia"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://www.ontolearn.com/ontologia">
        <dcterms:description xml:lang="pt">Ontologia para análise de aprendizagem baseada em competências.</dcterms:description>
        <dcterms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:title xml:lang="pt">Ontologia OntoLearn</dcterms:title>
        <rdfs:comment xml:lang="pt">Ontologia OntoLearn - Versão Final (Com Licença). Correção de P04, P08, P11, P13, P20 e P41.</rdfs:comment>
        <rdfs:label xml:lang="pt">OntoLearn</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ontolearn.com/ontologia#abordaCompetencia -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#abordaCompetencia">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehAbordadaPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:comment xml:lang="pt">Relaciona um recurso educacional à competência que ele visa desenvolver.</rdfs:comment>
        <rdfs:label xml:lang="pt">aborda competência</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#adquiridaPor -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#adquiridaPor">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#conquistasAdquiridas"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#MilestoneDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:comment xml:lang="pt">Aprendiz que adquiriu esta conquista.</rdfs:comment>
        <rdfs:label xml:lang="pt">adquirida por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#aplicadaNoCurso -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#aplicadaNoCurso">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#avaliacoesAplicadas"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:comment xml:lang="pt">Curso ao qual a avaliação pertence.</rdfs:comment>
        <rdfs:label xml:lang="pt">aplicada no curso</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#aprendizAvaliado -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#aprendizAvaliado">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#teveDesempenhoAvaliado"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:comment xml:lang="pt">Indica o aprendiz associado a este registro de desempenho.</rdfs:comment>
        <rdfs:label xml:lang="pt">aprendiz avaliado</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#aprendizesInscritos -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#aprendizesInscritos">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#estaInscritoEm"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:comment xml:lang="pt">Lista os alunos matriculados no curso.</rdfs:comment>
        <rdfs:label xml:lang="pt">aprendizes inscritos</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#avaliaDesempenho -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#avaliaDesempenho">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#temDesempenhoAvaliadoPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:comment xml:lang="pt">Indica que o instrutor realizou a avaliação.</rdfs:comment>
        <rdfs:label xml:lang="pt">avalia desempenho</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#avaliacoesAplicadas -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#avaliacoesAplicadas">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:comment xml:lang="pt">Avaliações que compõem o curso.</rdfs:comment>
        <rdfs:label xml:lang="pt">avaliações aplicadas</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#avaliadaPelaQuestao -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#avaliadaPelaQuestao">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#competenciasAvaliadas"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:comment xml:lang="pt">Questões usadas para avaliar a competência.</rdfs:comment>
        <rdfs:label xml:lang="pt">avaliada pela questão</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#competenciaRelacionada -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#competenciaRelacionada">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#temQuestaoRelacionada"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:comment xml:lang="pt">Associa uma questão à competência abordada.</rdfs:comment>
        <rdfs:label xml:lang="pt">competência relacionada</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#competenciasAvaliadas -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#competenciasAvaliadas">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:comment xml:lang="pt">Competências medidas por esta questão.</rdfs:comment>
        <rdfs:label xml:lang="pt">competências avaliadas</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#competenciasDoDesempenho -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#competenciasDoDesempenho">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#desempenhoCompetencias"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:comment xml:lang="pt">Relaciona o registro de desempenho ao aprendiz.</rdfs:comment>
        <rdfs:label xml:lang="pt">competências do desempenho</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#competenciasEnvolvidas -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#competenciasEnvolvidas">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehEnvolvidaEm"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ontolearn.com/ontologia#MilestoneDeAprendizagem"/>
                    <rdf:Description rdf:about="http://www.ontolearn.com/ontologia#TrajetoriasDeAprendizagem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:comment xml:lang="pt">Competências trabalhadas em milestones ou trajetórias.</rdfs:comment>
        <rdfs:label xml:lang="pt">competências envolvidas</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#compoeAtitudeEm -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#compoeAtitudeEm">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehCompostoDeAtitude"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Atitude"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:comment xml:lang="pt">Competência da qual a atitude faz parte.</rdfs:comment>
        <rdfs:label xml:lang="pt">compõe (atitude)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#compoeConhecimentoEm -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#compoeConhecimentoEm">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehCompostoDeConhecimento"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Conhecimento"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:comment xml:lang="pt">Competência da qual o conhecimento faz parte.</rdfs:comment>
        <rdfs:label xml:lang="pt">compõe (conhecimento)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#compoeHabilidadeEm -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#compoeHabilidadeEm">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#ehCompostoDeHabilidade"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Habilidade"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:comment xml:lang="pt">Competência da qual a habilidade faz parte.</rdfs:comment>
        <rdfs:label xml:lang="pt">compõe (habilidade)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#conquistasAdquiridas -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#conquistasAdquiridas">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#MilestoneDeAprendizagem"/>
        <rdfs:comment xml:lang="pt">Marcos alcançados pelo estudante.</rdfs:comment>
        <rdfs:label xml:lang="pt">conquistas adquiridas</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#desempenhoCompetencias -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#desempenhoCompetencias">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:comment xml:lang="pt">Relaciona o aprendiz aos registros de seu desempenho.</rdfs:comment>
        <rdfs:label xml:lang="pt">desempenho em competências</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#ehAbordadaPor -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehAbordadaPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:comment xml:lang="pt">Indica quais recursos educacionais cobrem esta competência.</rdfs:comment>
        <rdfs:label xml:lang="pt">é abordada por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#ehCompostoDeAtitude -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehCompostoDeAtitude">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Atitude"/>
        <rdfs:comment xml:lang="pt">Atitudes que compõem a competência.</rdfs:comment>
        <rdfs:label xml:lang="pt">é composto de atitude</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#ehCompostoDeConhecimento -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehCompostoDeConhecimento">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Conhecimento"/>
        <rdfs:comment xml:lang="pt">Conhecimentos teóricos que compõem a competência.</rdfs:comment>
        <rdfs:label xml:lang="pt">é composto de conhecimento</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#ehCompostoDeHabilidade -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehCompostoDeHabilidade">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Habilidade"/>
        <rdfs:comment xml:lang="pt">Habilidades práticas que compõem a competência.</rdfs:comment>
        <rdfs:label xml:lang="pt">é composto de habilidade</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#ehEnvolvidaEm -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehEnvolvidaEm">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ontolearn.com/ontologia#MilestoneDeAprendizagem"/>
                    <rdf:Description rdf:about="http://www.ontolearn.com/ontologia#TrajetoriasDeAprendizagem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="pt">Milestones ou trajetórias que envolvem a competência.</rdfs:comment>
        <rdfs:label xml:lang="pt">é envolvida em</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#ehExigidoPor -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehExigidoPor">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#exigeNivel"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#NiveisDeProficiencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:comment xml:lang="pt">Questões que exigem este nível.</rdfs:comment>
        <rdfs:label xml:lang="pt">é exigido por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#ehRequeridaPor -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehRequeridaPor">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#requer"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Competencia"/>
        <rdfs:comment xml:lang="pt">Competências que exigem esta como pré-requisito.</rdfs:comment>
        <rdfs:label xml:lang="pt">é requerida por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#ehResponsavelPor -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#ehResponsavelPor">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#instrutoresResponsaveis"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:comment xml:lang="pt">Cursos coordenados pelo instrutor.</rdfs:comment>
        <rdfs:label xml:lang="pt">é responsável por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#elaboraAvaliacoes -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#elaboraAvaliacoes">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#elaboradaPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:comment xml:lang="pt">Indica que o instrutor criou a avaliação.</rdfs:comment>
        <rdfs:label xml:lang="pt">elabora avaliações</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#elaboradaPor -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#elaboradaPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:comment xml:lang="pt">Instrutor responsável pela criação.</rdfs:comment>
        <rdfs:label xml:lang="pt">elaborada por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#estaInscritoEm -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#estaInscritoEm">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:comment xml:lang="pt">Cursos nos quais o aprendiz está matriculado.</rdfs:comment>
        <rdfs:label xml:lang="pt">está inscrito em</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#exigeNivel -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#exigeNivel">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#NiveisDeProficiencia"/>
        <rdfs:comment xml:lang="pt">Nível de proficiência necessário.</rdfs:comment>
        <rdfs:label xml:lang="pt">exige nível</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#fazParteDaAvaliacao -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#fazParteDaAvaliacao">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#questoesIncluidas"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Questao"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Avaliacao"/>
        <rdfs:comment xml:lang="pt">Indica a qual avaliação a questão pertence.</rdfs:comment>
        <rdfs:label xml:lang="pt">faz parte da avaliação</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#foiAtingidaEm -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#foiAtingidaEm">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#proficienciaAtingida"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#NiveisDeProficiencia"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#DesempenhoDoAprendiz"/>
        <rdfs:comment xml:lang="pt">Registros onde este nível foi atingido.</rdfs:comment>
        <rdfs:label xml:lang="pt">foi atingida em</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#historicoAprendizagem -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#historicoAprendizagem">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#parteDoHistoricoDe"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Aprendiz"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:comment xml:lang="pt">Recursos consumidos pelo aprendiz.</rdfs:comment>
        <rdfs:label xml:lang="pt">histórico de aprendizagem</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#insereRecursos -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#insereRecursos">
        <owl:inverseOf rdf:resource="http://www.ontolearn.com/ontologia#inseridoPor"/>
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:comment xml:lang="pt">Indica que o instrutor disponibilizou um recurso.</rdfs:comment>
        <rdfs:label xml:lang="pt">insere recursos</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#inseridoPor -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#inseridoPor">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#RecursoDeAprendizagem"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:comment xml:lang="pt">Instrutor que inseriu o recurso.</rdfs:comment>
        <rdfs:label xml:lang="pt">inserido por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontolearn.com/ontologia#instrutoresResponsaveis -->

    <owl:ObjectProperty rdf:about="http://www.ontolearn.com/ontologia#instrutoresResponsaveis">
        <rdfs:domain rdf:resource="http://www.ontolearn.com/ontologia#Curso"/>
        <rdfs:range rdf:resource="http://www.ontolearn.com/ontologia#Instrutor"/>
        <rdfs:comment xml:lang="pt">Instrutores que ministram o curso.</rdfs:comment>
